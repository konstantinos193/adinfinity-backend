# PostgreSQL connection string (Render provides this automatically via fromDatabase)
DATABASE_URL="postgresql://user:password@host:5432/invitations"

# JWT — use a long random string in production (Render can auto-generate)
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Gmail credentials for RSVP email notifications
# Use an App Password (not your main password): https://myaccount.google.com/apppasswords
EMAIL_USER="your-gmail@gmail.com"
EMAIL_PASS="your-app-password"

# Frontend domain(s) for CORS — comma-separated if multiple
# e.g. "https://invitations.adifinity.gr" or "https://foo.vercel.app,https://bar.vercel.app"
# Leave unset to allow all origins (fine for local dev)
FRONTEND_URL="https://your-frontend-domain.com"

# Server port — Render sets this automatically, do not override on Render
PORT=3001
